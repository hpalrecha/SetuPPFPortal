# =============================================================================
# PULSE VAS — ENVIRONMENT CONFIGURATION GUIDE
# =============================================================================
# Copy this file to .env and fill in all required values before running.
#
# WHO USES THIS SYSTEM?
# Pulse VAS connects multiple organizations in the PPF (Paint Protection Film)
# installation workflow. Here is a plain-english breakdown of each user type:
#
#  ┌─────────────────┬──────────────────────────────────────────────────────────┐
#  │ User / Tenant   │ What they do in Pulse VAS                                │
#  ├─────────────────┼──────────────────────────────────────────────────────────┤
#  │ SUPER_ADMIN     │ P91 internal team. Full access to everything: all OEMs,  │
#  │                 │ dealerships, partners, pricing, commissions, payouts, and │
#  │                 │ system configuration. Only role that can delete records.  │
#  ├─────────────────┼──────────────────────────────────────────────────────────┤
#  │ ADMIN           │ Senior P91 staff. Same as SUPER_ADMIN but cannot delete  │
#  │                 │ any records. Can create/edit everything else.             │
#  ├─────────────────┼──────────────────────────────────────────────────────────┤
#  │ MANAGER         │ Regional P91 manager. Read-only view filtered by their   │
#  │                 │ allowed states. Can create work orders and sales persons  │
#  │                 │ only for dealerships/showrooms in their allowed states.   │
#  ├─────────────────┼──────────────────────────────────────────────────────────┤
#  │ OEM_ADMIN       │ Car brand representative (e.g. Hyundai India). Manages   │
#  │                 │ their brand's dealerships, showrooms, pricing rules, and  │
#  │                 │ views OEM-level royalty commissions.                      │
#  ├─────────────────┼──────────────────────────────────────────────────────────┤
#  │ DEALERSHIP_ADMIN│ Dealership owner/manager (e.g. Mumbai Hyundai). Manages  │
#  │                 │ their showrooms, approves job cards, views sales          │
#  │                 │ commissions, and tracks orders across their showrooms.    │
#  ├─────────────────┼──────────────────────────────────────────────────────────┤
#  │ SHOWROOM_MANAGER│ Individual showroom manager. Views and creates work       │
#  │                 │ orders for their showroom, tracks installation status,    │
#  │                 │ and views their showroom's commissions.                   │
#  ├─────────────────┼──────────────────────────────────────────────────────────┤
#  │ SALES_PERSON    │ Car sales staff at a showroom. Creates work orders for   │
#  │                 │ customers buying PPF, tracks their order status, and      │
#  │                 │ earns commissions on successful installations.            │
#  ├─────────────────┼──────────────────────────────────────────────────────────┤
#  │ PARTNER_ADMIN   │ PPF installation studio/detailer owner. Receives job     │
#  │                 │ cards, manages their team, submits installation photos,   │
#  │                 │ applies for e-warranties, and tracks their payouts.       │
#  ├─────────────────┼──────────────────────────────────────────────────────────┤
#  │ PARTNER_STAFF   │ Installer/technician employed by a partner studio.       │
#  │                 │ Views assigned job cards, uploads pre-installation        │
#  │                 │ photos, and updates job card status during installation.  │
#  └─────────────────┴──────────────────────────────────────────────────────────┘
#
# ORGANIZATIONAL HIERARCHY:
#   OEM (e.g. Hyundai India)
#     └── Dealership (e.g. Mumbai Hyundai)
#           └── Showroom (e.g. Andheri Branch)
#                 └── Sales Person → creates Work Order → triggers Job Card
#                                                              └── Partner (Installer)
#
# =============================================================================


# =============================================================================
# 1. APPLICATION SETTINGS
# =============================================================================
# Controls the runtime environment. Use "production" on your live server.
# In development mode, certain security checks are relaxed and emails are
# logged to the console instead of being sent.
NODE_ENV=development

# Port the server listens on. Defaults to 5000 if not set.
PORT=5000

# The public URL of this application. Used in:
#  - Password reset email links sent to users
#  - Job card deep links sent via WhatsApp to installation partners
#  - E-warranty notification emails
# Set this to your custom domain in production (e.g. https://pulse.p91india.com)
PRODUCTION_URL=https://your-custom-domain.com

# Fallback URL used if PRODUCTION_URL is not set. Usually auto-set on Replit.
FRONTEND_URL=http://localhost:5000

# Auto-set by Replit. Do not change this manually.
REPLIT_DEV_DOMAIN=your-repl-name.replit.app


# =============================================================================
# 2. DATABASE — PostgreSQL
# =============================================================================
# All application data is stored here: users, organizations, work orders,
# job cards, pricing rules, commissions, payouts, audit logs, and more.
#
# On Replit: this is auto-provisioned. Copy the value from the Database tab.
# Self-hosted: create a PostgreSQL 15+ database and set the connection string.
DATABASE_URL=postgresql://username:password@localhost:5432/pulse_vas_db

# Individual PostgreSQL connection details (used as fallback if DATABASE_URL
# is not set, or by database management tools like psql and Drizzle Studio)
PGHOST=localhost
PGPORT=5432
PGDATABASE=pulse_vas_db
PGUSER=username
PGPASSWORD=password


# =============================================================================
# 3. AUTHENTICATION — JWT (JSON Web Tokens)
# =============================================================================
# Used to sign and verify login tokens for all users across all tenant types.
# IMPORTANT: Use a long, random string (minimum 32 characters). If this value
# changes, all existing user sessions will be invalidated and everyone will be
# logged out.
#
# Generate a secure secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-secret-minimum-32-characters


# =============================================================================
# 4. BACKGROUND JOBS — Redis
# =============================================================================
# Redis powers background job processing for:
#  - Email & WhatsApp notification queues (so API responses aren't delayed)
#  - SLA monitoring (checks if job cards are overdue every hour)
#  - Outbound webhook delivery with retry logic
#  - Dashboard report caching (60-second TTL for performance)
#
# On Replit: Redis is available via the built-in Redis integration.
# Self-hosted: Redis 7+ recommended.
REDIS_URL=redis://localhost:6379

# Kept separate in case notification queue uses a different Redis instance
NOTIFICATION_QUEUE_REDIS_URL=redis://localhost:6379


# =============================================================================
# 5. FILE STORAGE — Replit Object Storage (Google Cloud Storage)
# =============================================================================
# Used to store job card media files:
#  - Pre-installation inspection photos (4 mandatory photos per job card:
#    Front, Back, Left Side, Right Side — required before starting work)
#  - Additional proof-of-work photos uploaded by partners during installation
#  - E-warranty related document uploads
#
# Files are stored with private ACLs and accessed via signed URLs (1-hour TTL)
# to ensure only authorized users can view sensitive installation photos.
#
# On Replit: Created automatically by the Object Storage integration.
# The bucket is named: repl-default-bucket-{REPL_ID}
DEFAULT_OBJECT_STORAGE_BUCKET_ID=your-replit-bucket-id

# Path inside the bucket for private uploads (installation photos, etc.)
# These files require a signed URL to access — they are NOT publicly accessible.
PRIVATE_OBJECT_DIR=.private/uploads

# Comma-separated paths for publicly accessible assets (logos, static images)
PUBLIC_OBJECT_SEARCH_PATHS=public/assets,public/media


# =============================================================================
# 6. EMAIL — AWS Simple Email Service (SES) via SMTP
# =============================================================================
# Emails are sent from: noreply@p91india.com
#
# WHO RECEIVES EMAILS AND WHEN:
#
#  ┌──────────────────────────────┬───────────────────────────────────────────┐
#  │ Email Trigger                │ Recipient                                 │
#  ├──────────────────────────────┼───────────────────────────────────────────┤
#  │ Work order created           │ Partner (installation studio)             │
#  │ Job card completed           │ Dealership/Showroom manager               │
#  │ Job card approved            │ Partner (confirmation + payout info)      │
#  │ E-warranty application       │ STEK India team (warranty processing)     │
#  │ Job card pending invoice     │ Accounts team (invoice required)          │
#  │ Password reset               │ Any user who requests reset               │
#  │ OTP verification             │ Any user logging in with OTP              │
#  │ New partner account created  │ Partner admin (Pulse webhook trigger)     │
#  └──────────────────────────────┴───────────────────────────────────────────┘
#
# HOW IT WORKS:
#  Primary method: AWS SES via SMTP (nodemailer) — currently active
#  Fallback method: AWS SES SDK (disabled — was causing 15s timeouts)
#  Dev mode: If no credentials set, emails are logged to console only.
#
# SETUP: Go to AWS Console → SES → SMTP Settings → Create SMTP Credentials
# Region used: ap-south-1 (Mumbai, India)

# SMTP credentials (preferred — use these for best performance)
SES_SMTP_USERNAME=your-ses-smtp-username
SES_SMTP_PASSWORD=your-ses-smtp-password

# AWS region where your SES account is verified
AWS_REGION=ap-south-1

# AWS SDK credentials (only needed if SES SDK method is re-enabled)
# These are separate from SMTP credentials above
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key


# =============================================================================
# 7. SMS — ComBirds (EduMarc SMS API)
# =============================================================================
# Used for sending OTP codes during user login/verification.
# SMS is sent to Indian mobile numbers in the format: 91XXXXXXXXXX
#
# OTP Template (DLT registered):
#   "Your Pulse VAS OTP for verification is: {otp}. OTP is confidential,
#    refrain from sharing it with anyone. By Edumarc Technologies"
#
# WHO RECEIVES SMS:
#  - Any user (all tenant types) who uses OTP-based login or verification
#
# SETUP: Get your API key from https://smsapi.edumarcsms.com
# DLT Template ID used: 1707168926925165526 (pre-registered, do not change)

# API key from ComBirds/EduMarc dashboard
COMBIRDS_OTP_API_KEY=your-combirds-api-key

# Sender ID (header) registered with DLT for your OTP messages
# Default: EDUMRC — change only if you have a different registered header
COMBIRDS_HEADER=EDUMRC


# =============================================================================
# 8. WHATSAPP — Meta Business API (WABA)
# =============================================================================
# Used to send real-time WhatsApp notifications to installation partners.
# All messages use pre-approved Meta message templates.
#
# WHO RECEIVES WHATSAPP MESSAGES AND WHEN:
#
#  ┌─────────────────────────────────┬──────────────────────────────────────┐
#  │ Event                           │ Message Sent To                      │
#  ├─────────────────────────────────┼──────────────────────────────────────┤
#  │ Job card created / assigned     │ Partner (PARTNER_ADMIN/STAFF)        │
#  │ Job card approved               │ Partner — confirms approval          │
#  │ Job card rejected               │ Partner — includes rejection reason  │
#  │ Job card pending approval       │ Dealership/Showroom manager          │
#  │ Job card completed              │ Showroom manager (for review)        │
#  └─────────────────────────────────┴──────────────────────────────────────┘
#
# Each message includes a deep link to the job card:
#   https://your-domain.com/job-cards/{jobCardId}
# Partners can click the link to open the job card directly in the app.
#
# SETUP: Go to Meta Business Suite → WhatsApp → API Setup
#  1. Create a WhatsApp Business Account (WABA)
#  2. Get your Phone Number ID (the number messages are sent FROM)
#  3. Generate a permanent access token
#  4. Note your Business Account ID
#
# API version used: v18.0 (Meta Graph API)

# Long-lived access token from Meta Business Suite
META_WABA_ACCESS_TOKEN=your-meta-whatsapp-access-token

# Phone Number ID of the WhatsApp number used to send messages
# Found in Meta Business Suite → WhatsApp → Phone Numbers
META_WABA_PHONE_NUMBER_ID=your-phone-number-id

# Your WhatsApp Business Account ID (not the phone number itself)
META_WABA_BUSINESS_ACCOUNT_ID=your-business-account-id

# Meta Graph API version. Only change if Meta announces a deprecation.
META_WABA_API_VERSION=v18.0


# =============================================================================
# 9. PULSE INTEGRATION — Inbound Webhook
# =============================================================================
# Pulse is the external partner management system. When a partner (installer
# studio) is activated or deactivated in Pulse, it automatically creates or
# deactivates their account in Pulse VAS via this webhook.
#
# WHAT HAPPENS WHEN PULSE SENDS A WEBHOOK:
#
#  "activate" action:
#   - A new partner organization is created in Pulse VAS
#   - PARTNER_ADMIN and PARTNER_STAFF user accounts are created
#   - A welcome email with login credentials is sent to the partner
#   - Partner type is set based on role: STUDIO (full service) or INSTALLER (mobile)
#
#  "deactivate" action:
#   - The partner's PARTNER_ADMIN and PARTNER_STAFF accounts are deactivated
#   - They can no longer log in until reactivated
#   - Existing job cards and history are preserved
#
# SECURITY: Each webhook request from Pulse is verified using HMAC-SHA256
# signature. The same secret must be configured in both Pulse and here.
# Requests older than 5 minutes are automatically rejected (replay protection).
#
# Webhook endpoint: POST /api/webhooks/pulse/user-access
# Signature header: X-Pulse-Signature

# Secret key shared between Pulse and Pulse VAS for webhook verification
# Must match exactly what is configured in the Pulse system settings
PULSE_WEBHOOK_SECRET=your-shared-hmac-secret-with-pulse-system


# =============================================================================
# 10. OUTBOUND WEBHOOKS — Event Notifications to External Systems
# =============================================================================
# Pulse VAS can notify external systems (like ERPNext, CRMs, or custom tools)
# when key events happen inside the platform.
#
# EVENTS THAT TRIGGER OUTBOUND WEBHOOKS:
#  - work_order.created / updated / cancelled
#  - job_card.created / status_changed / approved / rejected
#  - partner.allocated / commission.calculated
#  - payout.approved / settled
#  - whatsapp.message (incoming WhatsApp message received)
#
# Each webhook payload is signed with HMAC-SHA256 using WEBHOOK_SECRET so the
# receiving system can verify the request came from Pulse VAS.
# Webhooks are delivered with retry logic via the background job queue.
#
# SETUP: Configure webhook endpoints per OEM/partner in the admin dashboard.
# Each registered endpoint receives events scoped to their organization only.

# Secret used to sign outgoing webhook payloads (HMAC-SHA256)
# The receiving system uses this to verify authenticity of each request
WEBHOOK_SECRET=your-outbound-webhook-signing-secret


# =============================================================================
# 11. SLA MONITORING — Job Card Deadlines
# =============================================================================
# The system automatically monitors job cards for SLA (Service Level Agreement)
# breaches and sends alerts when partners haven't responded in time.
#
# SLA RULES:
#  - After a job card is created, the partner has AWAITING_ACK_HOURS to
#    acknowledge it. After this window, an SLA breach alert is triggered.
#  - After a job card is scheduled, the partner has SCHEDULED_GRACE_HOURS
#    to start work before a breach alert is raised.
#
# AFFECTS: Partners (PARTNER_ADMIN/STAFF) and OEM/Dealership admins
# who receive breach notifications.

# Hours a partner has to acknowledge a new job card before SLA breach
SLA_AWAITING_ACK_HOURS=24

# Hours of grace period after scheduled time before SLA breach is flagged
SLA_SCHEDULED_GRACE_HOURS=2


# =============================================================================
# 12. FILE UPLOAD LIMITS
# =============================================================================
# Controls what partners can upload as installation proof photos.
# These are enforced on the server side for all file uploads.
#
# AFFECTS: PARTNER_ADMIN and PARTNER_STAFF uploading:
#  - Pre-installation inspection photos (4 required per job card)
#  - Work-in-progress and completion photos
#
# NOTE: The mobile image upload system automatically compresses photos to
# under 1MB and converts HEIC/HEIF (iOS) photos to JPEG before upload,
# so partners using iPhones don't need to worry about format or size.

# Maximum file size in megabytes per upload
MAX_FILE_SIZE_MB=10

# Comma-separated list of allowed MIME types for file uploads
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/jpg,video/mp4

# Minimum number of proof images required for job card completion
MIN_PROOF_IMAGES=3


# =============================================================================
# QUICK REFERENCE — ALL ENVIRONMENT VARIABLES
# =============================================================================
#
# REQUIRED (app will not start without these):
#   DATABASE_URL          — PostgreSQL connection string
#   JWT_SECRET            — Authentication token signing key
#   REDIS_URL             — Background job queue
#
# REQUIRED FOR EMAIL (users won't receive any emails without these):
#   SES_SMTP_USERNAME     — AWS SES SMTP username
#   SES_SMTP_PASSWORD     — AWS SES SMTP password
#   AWS_REGION            — AWS region (default: ap-south-1)
#
# REQUIRED FOR WHATSAPP (partners won't receive job notifications):
#   META_WABA_ACCESS_TOKEN        — Meta WhatsApp API token
#   META_WABA_PHONE_NUMBER_ID     — Sender phone number ID
#   META_WABA_BUSINESS_ACCOUNT_ID — WhatsApp Business Account ID
#
# REQUIRED FOR SMS OTP (OTP login won't work without this):
#   COMBIRDS_OTP_API_KEY  — ComBirds SMS API key
#   COMBIRDS_HEADER       — DLT sender ID header
#
# REQUIRED FOR PULSE PARTNER SYNC (new partners won't auto-create):
#   PULSE_WEBHOOK_SECRET  — HMAC secret shared with Pulse system
#
# OPTIONAL BUT RECOMMENDED:
#   PRODUCTION_URL        — Custom domain for email/WhatsApp links
#   WEBHOOK_SECRET        — For outbound webhook security
#   DEFAULT_OBJECT_STORAGE_BUCKET_ID — For file storage
#
# =============================================================================
