# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/setuppf_db

# PostgreSQL Connection Details (alternative to DATABASE_URL)
PGHOST=localhost
PGPORT=5432
PGDATABASE=setuppf_db
PGUSER=username
PGPASSWORD=password

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Object Storage Configuration
# Create buckets in the Object Storage tool and set these paths
PRIVATE_OBJECT_DIR=/setuppf-private/uploads
PUBLIC_OBJECT_SEARCH_PATHS=/setuppf-public/assets,/setuppf-public/media

# Default Object Storage Bucket (for Replit)
DEFAULT_OBJECT_STORAGE_BUCKET_ID=your-bucket-id

# Application Configuration
NODE_ENV=development
PORT=5000

# Email/SMS Configuration (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@domain.com
SMTP_PASS=your-email-password

# WhatsApp API Configuration (optional)
WHATSAPP_API_URL=https://api.whatsapp.com
WHATSAPP_API_TOKEN=your-whatsapp-token

# Webhook Configuration
WEBHOOK_SECRET=your-webhook-secret-for-hmac-verification

# SLA Configuration
SLA_AWAITING_ACK_HOURS=24
SLA_SCHEDULED_GRACE_HOURS=2
MIN_PROOF_IMAGES=3

# File Upload Configuration
MAX_FILE_SIZE_MB=10
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/jpg,video/mp4

# Cache Configuration
REDIS_URL=redis://localhost:6379

# Notification Configuration
NOTIFICATION_QUEUE_REDIS_URL=redis://localhost:6379
